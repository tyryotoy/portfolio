{
    "name": "app",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint --dir src",
        "lint:fix": "eslint src --ext .js,jsx,.ts,.tsx --fix",
        "format": "prettier --write --ignore-path .gitignore './**/*.{js,jsx,ts,tsx,json,css}'"
    },
    "dependencies": {
        "next": "12.0.9",
        "react": "17.0.2",
        "react-dom": "17.0.2"
    },
    "devDependencies": {
        "@types/node": "17.0.13",
        "@types/react": "17.0.38",
        "autoprefixer": "^10.4.2",
        "eslint": "8.7.0",
        "eslint-config-next": "12.0.9",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-tailwindcss": "^3.3.6",
        "postcss": "^8.4.5",
        "prettier": "^2.6.0",
        "tailwindcss": "^3.0.18",
        "typescript": "4.5.5"
    },
    "prettier": {
        "trailingComma": "all",
        "tabWidth": 4,
        "semi": true,
        "singleQuote": true,
        "jsxSingleQuote": true,
        "printWidth": 100
    }
}
